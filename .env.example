# ═══════════════════════════════════════════════════════════
# AUTOPILOT AGENT — Configuration
# All settings are controlled from this single file.
# Restart the app after making changes.
# ═══════════════════════════════════════════════════════════

# ── OpenAI API ─────────────────────────────────────────────
# Your OpenAI API key (required)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-YOUR_KEY_HERE"

# ── Runner Server ──────────────────────────────────────────
# Host and port for the Fastify runner backend
# Use 0.0.0.0 for production (accepts external connections)
HOST="127.0.0.1"
PORT="4001"

# ── Agent Model & Mode ─────────────────────────────────────
# Model: "gpt-5.4-mini" (fast, cheap) or "gpt-5.4" (smarter, costly)
CUA_DEFAULT_MODEL="gpt-5.4-mini"

# Execution mode:
#   "native" — model sees screenshots, clicks/types like a human (best for general use)
#   "code"   — model writes Playwright JS to control the browser (more precise)
CUA_EXECUTION_MODE="native"

# Reasoning effort: how much the model "thinks" before each action
#   "low"    — fast but may miss nuances (cheapest)
#   "medium" — balanced thinking and cost (recommended)
#   "high"   — deep reasoning, slower and more expensive (best for complex tasks)
CUA_REASONING_EFFORT="low"

# Responses mode:
#   "auto" — uses mock responses in test, live API otherwise
#   "live" — always calls OpenAI API (use this for production)
CUA_RESPONSES_MODE="auto"

# ── Browser Settings ───────────────────────────────────────
# Browser mode:
#   "headless" — no visible browser window (production)
#   "headful"  — visible browser window (debugging)
CUA_BROWSER_MODE="headless"

# Viewport size (pixels): what resolution the agent "sees"
# OpenAI recommends 1440x900 or 1600x900 for best accuracy
# Smaller = fewer tokens but may miss small UI elements
CUA_VIEWPORT_WIDTH="1440"
CUA_VIEWPORT_HEIGHT="900"

# ── Persistent Storage ─────────────────────────────────────
# Directory where Playwright keeps your Google Chrome profile, cookies, and active sessions.
# On a VM/server, set an absolute path outside the repository to prevent wiping logins on redeploys.
#CUA_BROWSER_PROFILE_DIR="./data/browser-profile"

# ── Performance Tuning ─────────────────────────────────────
# Max turns: how many screenshot→action cycles per run (1 turn ≈ 1 API call)
# Higher = handles longer tasks, but costs more
CUA_MAX_RESPONSE_TURNS="36"

# Step delay: ms between runner steps (lower = faster, higher = more stable)
CUA_STEP_DELAY_MS="650"

# Inter-action delay: ms between individual browser actions within a turn
CUA_INTER_ACTION_DELAY_MS="120"

# Tool timeout: ms before a tool execution is aborted
CUA_TOOL_TIMEOUT_MS="20000"

# ── Deployment Environments ────────────────────────────────
# Use these commented blocks as a pure quick-start backup for your environments.
# Uncomment the block that matches your server!

# [ LOCAL DEVELOPMENT ] 
# HOST="127.0.0.1"
# RUNNER_BASE_URL="http://127.0.0.1:4001"
# CUA_BROWSER_PROFILE_DIR="./data/browser-profile"
# CUA_WEBHOOK_URL="http://127.0.0.1:5678/webhook/cua-task-complete"

# [ STAGING SERVER ] 
# HOST="0.0.0.0"
# RUNNER_BASE_URL="https://staging.agent.silmma.com/api"
# CUA_BROWSER_PROFILE_DIR="/opt/cua-agent-staging/browser-profile"
# CUA_WEBHOOK_URL="https://n8n.staging.silmma.com/webhook/cua-task-complete"

# [ PRODUCTION SERVER ] 
# HOST="0.0.0.0"
# RUNNER_BASE_URL="https://agent.silmma.com/api"
# CUA_BROWSER_PROFILE_DIR="/opt/cua-agent/browser-profile"
# CUA_WEBHOOK_URL="https://n8n.silmma.com/webhook/cua-task-complete"

# ── Branding ───────────────────────────────────────────────
# App name shown in the topbar and browser tab
NEXT_PUBLIC_APP_NAME="Agent John Wicks"

# Subtitle shown below the app name
NEXT_PUBLIC_APP_SUBTITLE="Give a URL and instructions — the agent handles the rest."

# ── Browser Locale ─────────────────────────────────────────
# Locale for the browser (affects language of pages the agent sees)
CUA_BROWSER_LOCALE="en-US"

# These NEXT_PUBLIC_ vars are exposed to the browser (client-side)
NEXT_PUBLIC_CUA_DEFAULT_MODEL="gpt-5.4-mini"
NEXT_PUBLIC_CUA_DEFAULT_MAX_RESPONSE_TURNS="36"

# ── Integrations ───────────────────────────────────────────
# Optional: n8n webhook URL for task completion notifications
# When set, the agent POSTs results to this URL on every task completion
CUA_WEBHOOK_URL="https://n8n.silmma.com/webhook/cua-task-complete"

NEXT_PUBLIC_OPTIMIZE_WEBHOOK_URL="https://n8n.silmma.com/webhook/optimize-prompt"

# Required: n8n webhook URL for syncing agent prompts from Google Sheet
# The agent fetches all prompts from this endpoint at startup
CUA_PROMPTS_WEBHOOK_URL="https://n8n.silmma.com/webhook/agent-prompts"